{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "cppvsdbg",
            "request": "launch",
            "name": "Debug",
            "program": "${workspaceFolder}/target/debug/rust-triangle.exe",
            "preLaunchTask": "cargo build debug",
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "cppvsdbg",
            "request": "launch",
            "name": "Release",
            "program": "${workspaceFolder}/target/release/rust-triangle.exe",
            "preLaunchTask": "cargo build release",
            "cwd": "${workspaceFolder}"
        }
    ]
}