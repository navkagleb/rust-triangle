// Project-local debug tasks
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
  {
    "label": "Debug",
    "adapter": "CodeLLDB",
    "build": {
      "command": "cargo",
      "args": ["build"],
    },
    "program": "$ZED_WORKTREE_ROOT/target/debug/rust-triangle.exe",
    "request": "launch",
    "cwd": "$ZED_WORKTREE_ROOT",
  },
  {
    "label": "Release",
    "adapter": "CodeLLDB",
    "build": {
      "command": "cargo",
      "args": ["build", "--release"],
    },
    "program": "$ZED_WORKTREE_ROOT/target/release/rust-triangle.exe",
    "request": "launch",
    "cwd": "$ZED_WORKTREE_ROOT",
  },
]
